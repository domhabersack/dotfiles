#!/bin/sh
# Sets @tmux_color on each window based on ~/.dotfiles/window-colors.
# window-status-format reads #{@tmux_color} to colorize the status-bar entry.
# Strips task-indicator emojis before matching so colored windows stay colored
# after task indicators are appended/removed.

CONFIG="$HOME/.dotfiles/window-colors"

# Atomic re-entrancy lock — prevents concurrent runs spawned by rapid renames.
# Only sets window options (never renames), so it cannot itself trigger a hook loop.
lock=/tmp/tmux-color-windows.lock
mkdir "$lock" 2>/dev/null || exit 0
trap 'rm -rf "$lock"' EXIT

[ -f "$CONFIG" ] || exit 0

# Build a lookup table: window_name TAB color_spec
# Reads the config once; color_spec is the content between [ and ], e.g. "fg=colour39".
tmpfile=$(mktemp /tmp/tmux-color-windows.XXXXXX)
trap 'rm -f "$tmpfile"; rm -rf "$lock"' EXIT

current_color=""
while IFS= read -r line; do
  # Strip leading/trailing whitespace and skip blank lines and comments.
  line=$(printf '%s\n' "$line" | sed 's/^[[:space:]]*//;s/[[:space:]]*$//')
  case "$line" in
    ''|\#*) continue ;;
    '['*)
      current_color="${line#[}"
      current_color="${current_color%]}"
      ;;
    *)
      [ -n "$current_color" ] && printf '%s\t%s\n' "$line" "$current_color" >> "$tmpfile"
      ;;
  esac
done < "$CONFIG"

# Apply (or clear) the color variable on every window across all sessions.
tmux list-windows -a -F '#{window_id} #{window_name}' | \
while read -r wid name; do
  # Extract the leading slug ([a-zA-Z0-9.-]+) — ignores any suffix regardless of format.
  base=$(printf '%s' "$name" | sed 's/^\([a-zA-Z0-9.-]*\).*/\1/')

  # Look up the color for this slug (empty if not in any group).
  color=$(awk -F'\t' -v n="$base" '$1 == n { print $2; exit }' "$tmpfile")

  tmux set-window-option -t "$wid" @tmux_color "$color"
done
