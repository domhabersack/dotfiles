#!/bin/sh
# Renders a per-window "freshness" bar showing how recently each window was
# accessed, combining two independent signals into one bar:
#
#   - SHAPE: a CELLS-cell shaded meter that fills right-to-left from all-░
#     (touched long ago) up through partial shades to all-█ (touched just
#     now). Each cell steps ░ → ▒ → ▓ → █ before the next cell to its left
#     begins to darken, for 3*CELLS+1 stages in all, spread LOGARITHMICALLY
#     between FRESH and STALE so freshness drops off fast at first and then
#     ever more slowly — a window fades over ~2 weeks.
#
#   - COLOR: the whole bar is always a single solid color (never a per-cell
#     gradient), interpolated through green -> yellow -> orange -> red
#     across [0, FOURTEEN] (green fading to yellow within hours, then a
#     slow drift through orange to red by day 14), then falling through to
#     a grayscale fade for anything older than that, out to STALE. Color is
#     computed straight off elapsed time, independent of the shape/CELLS
#     above, so widening or narrowing the bar never affects which color a
#     given age shows.
#
# Every run stamps the active window of each attached session with the
# current time (@last_accessed). The bar is written to @last_accessed's
# sibling option @freshness, which window-status-format prints at the START
# of each entry. It is purely decorative: it is NOT part of window_name, so
# — like a leading marker emoji — it never influences window sorting or
# coloring.

# While bin/tmux-sort-windows is reshuffling windows, its move-window churn
# transiently changes the active window and fires the select-window hooks that
# call us. Bail out so we never stamp the wrong window as freshly accessed — the
# sort reselects the original window and triggers one clean render when it is done.
[ -d /tmp/tmux-sort-windows.lock ] && exit 0

now=$(date +%s)

# Tunables (seconds), split by which signal they drive.
#
# Shape: anything fresher than FRESH shows a full bar, anything older than
# STALE shows an empty bar, spread across the stages on a log scale. CELLS
# is purely the bar's width — it no longer constrains the color palette
# (color is computed independently of stage/CELLS, see below), so any width
# is safe.
FRESH=900         # <= this (15 min): brand-new, full bar
STALE=2592000     # >= this (~1 month): ancient, empty bar; also the far end
                  # of the grayscale tail (see FOURTEEN below)
CELLS=6           # bar width in cells; purely cosmetic

# Color: RGB interpolates green -> yellow -> orange -> red across three
# legs (see the anchor colors below), then falls through to the grayscale
# tail that fades out the rest of the way to STALE.
YELLOW_AT=21600   # <= this (6h): green fading to yellow
ORANGE_AT=604800  # <= this (7d): yellow fading to orange
FOURTEEN=1209600  # <= this (14d): orange fading to red
                  # >  this: grayscale, fading out further to STALE above

# Decide each window's stored access time. The active window of every attached
# session is (re)stamped "now", so the window you are looking at always reads as
# maximally fresh. A window that has never been stamped is initialized to "now"
# so it begins decaying from first sighting — without this it would default to
# "now" on every render and stay pinned at a full bar forever.
tmux list-windows -a -F '#{session_attached} #{window_active} #{window_id} #{@last_accessed}' |
while read -r attached active wid last; do
  if { [ "$attached" = "1" ] && [ "$active" = "1" ]; } || [ -z "$last" ]; then
    tmux set-window-option -t "$wid" @last_accessed "$now"
  fi
done

# Compute the bar for every window in one awk pass, then apply. A window with no
# recorded timestamp (e.g. just restored) is treated as accessed now.
tmux list-windows -a -F '#{window_id} #{@last_accessed}' |
awk -v now="$now" -v fresh="$FRESH" -v stale="$STALE" -v cells="$CELLS" \
    -v yellow_at="$YELLOW_AT" -v orange_at="$ORANGE_AT" -v fourteen="$FOURTEEN" '
BEGIN {
  level[0]="░"; level[1]="▒"; level[2]="▓"; level[3]="█"
  max_stage = 3 * cells   # top stage = full bar; stages run 0..max_stage

  # Anchor colors: Tailwind CSS v4 500-weight green/yellow/orange/red —
  # picked over a hand-tuned hue sweep because those are a professionally
  # designed, genuinely vibrant set (a fixed-saturation HSL sweep kept
  # landing too muted or too neon depending on the S/L chosen).
  gR=34;  gG=197; gB=94    # green-500  #22c55e
  yR=234; yG=179; yB=8     # yellow-500 #eab308
  oR=249; oG=115; oB=22    # orange-500 #f97316
  rR=239; rG=68;  rB=68    # red-500    #ef4444
}
{
  wid = $1
  ts  = ($2 == "" ? now : $2)
  elapsed = now - ts
  if (elapsed < 0) elapsed = 0

  # --- Shape: elapsed -> stage 0..max_stage, logarithmic between FRESH and
  # STALE. Unrelated to color below; changing CELLS only changes bar width.
  if (elapsed <= fresh)      stage = max_stage
  else if (elapsed >= stale) stage = 0
  else {
    frac  = log(elapsed / fresh) / log(stale / fresh)   # 0 (fresh) .. 1 (stale)
    stage = int(max_stage * (1 - frac) + 0.5)
  }

  # Render: "full" whole cells filled from the right, one partial cell of shade
  # "rem" to their left, the rest empty.
  full = int(stage / 3)
  rem  = stage % 3
  bar  = ""
  for (j = 0; j < cells; j++) {       # left cell (j=0) .. right cell (cells-1)
    r = (cells - 1) - j               # distance from the right edge
    if      (r <  full) lvl = 3       # fully black
    else if (r == full) lvl = rem     # the partially-filled cell
    else                lvl = 0       # still empty
    bar = bar level[lvl]
  }

  # --- Color: a single solid color for the whole bar (never a per-cell
  # gradient). RGB linearly interpolates across three legs — green->yellow
  # over [0, YELLOW_AT], yellow->orange over (YELLOW_AT, ORANGE_AT],
  # orange->red over (ORANGE_AT, FOURTEEN] — through the Tailwind anchors
  # above. Rendered as 24-bit truecolor so the color lands exactly (no
  # xterm-256 quantization); tmux transparently falls back to the nearest
  # xterm-256 color on terminals without RGB support. Beyond FOURTEEN this
  # is the same grayscale-ramp tail as before, fading out to STALE. Wrap the
  # bar in its own fg + trailing reset so @freshness is self-contained:
  # consumers just print #{@freshness} without having to reset the color.
  if (elapsed <= fourteen) {
    if (elapsed <= yellow_at) {
      t = elapsed / yellow_at
      R = gR + (yR-gR)*t; G = gG + (yG-gG)*t; B = gB + (yB-gB)*t
    } else if (elapsed <= orange_at) {
      t = (elapsed - yellow_at) / (orange_at - yellow_at)
      R = yR + (oR-yR)*t; G = yG + (oG-yG)*t; B = yB + (oB-yB)*t
    } else {
      t = (elapsed - orange_at) / (fourteen - orange_at)
      R = oR + (rR-oR)*t; G = oG + (rG-oG)*t; B = oB + (rB-oB)*t
    }
    bar = sprintf("#[fg=#%02x%02x%02x]%s#[default]", int(R+0.5), int(G+0.5), int(B+0.5), bar)
  } else {
    fracg = (elapsed - fourteen) / (stale - fourteen)
    if (fracg > 1) fracg = 1
    col = 232 + int(fracg * 23 + 0.5)
    bar = "#[fg=colour" col "]" bar "#[default]"
  }

  print wid "\t" bar
}' |
while IFS='	' read -r wid bar; do
  tmux set-window-option -t "$wid" @freshness "$bar"
done

# Repaint the status line so the bars update immediately, not just on the next
# status-interval tick.
tmux refresh-client -S 2>/dev/null
