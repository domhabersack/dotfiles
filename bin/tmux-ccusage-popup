#!/bin/sh
# ccusage lives under nvm's per-version bin dir, which isn't on PATH in the
# non-interactive shell tmux spawns for a popup; source nvm.sh to pick up the
# default version before invoking it.
export NVM_DIR="$HOME/.nvm"
[ -s "$NVM_DIR/nvm.sh" ] && . "$NVM_DIR/nvm.sh"
ccusage blocks --active
